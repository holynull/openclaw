# Server Configuration
HOST=0.0.0.0
PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.com

# SoftHSM Configuration
SOFTHSM_MODULE=/usr/local/lib/softhsm/libsofthsm2.so
HSM_TOKEN_LABEL=wallet-custody
HSM_PIN=your-hsm-user-pin

# Mnemonic Configuration
# ⚠️ IMPORTANT: The system will auto-generate a mnemonic on first initialization
# The mnemonic will be saved to a backup file ONE TIME ONLY
# You must backup the mnemonic and then delete the backup file
# HD wallet derivation path prefix (BIP44 for Ethereum: m/44'/60'/0'/0)
HD_PATH_PREFIX=m/44'/60'/0'/0
# Path where the one-time mnemonic backup will be saved
MNEMONIC_BACKUP_PATH=./mnemonic-backup.txt

# API Key Configuration
API_KEY_SALT=your-random-salt-for-api-keys
VALID_API_KEYS=hash1,hash2,hash3

# Audit Configuration
AUDIT_ENABLED=true
AUDIT_LOG_PATH=./logs/audit.log

# Logging
LOG_LEVEL=info

# Security Configuration
# IP 白名单（逗号分隔，留空表示不限制）
IP_WHITELIST=127.0.0.1,192.168.1.100

# 地址白名单（逗号分隔，留空表示不限制）
ADDRESS_WHITELIST=

# 地址黑名单（逗号分隔）
ADDRESS_BLACKLIST=

# 单笔交易金额限制（ETH）
MAX_TRANSACTION_AMOUNT=10

# 每日累计限额（ETH）
DAILY_LIMIT=100

# 高额交易阈值（超过此值需要告警，ETH）
HIGH_VALUE_THRESHOLD=5

# 是否需要多重签名审批
REQUIRE_MULTI_SIG=false

# Telegram 告警配置
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# 异常检测配置
MAX_REQUESTS_PER_MINUTE=10
MAX_FAILED_ATTEMPTS=5
